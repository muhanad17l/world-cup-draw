rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.username == 'muhanad');
    }

    // User profiles
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId || isAdmin();
    }

    // Posts
    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
      allow update, delete: if isSignedIn() && (resource.data.authorId == request.auth.uid || isAdmin());
    }

    // Tournaments & Matches
    match /tournaments/{tournamentId} {
      allow read: true;
      allow write: if isAdmin();
      
      match /matches/{matchId} {
        allow read: true;
        allow write: if isAdmin();
      }
    }

    // Top-level Matches (if used)
    match /matches/{matchId} {
      allow read: true;
      allow write: if isAdmin();
    }

    // Hall of Fame
    match /hall_of_fame/{entryId} {
      allow read: true;
      allow write: if isAdmin();
    }

    // Notifications
    match /notifications/{notifId} {
      allow read: if isSignedIn() && resource.data.receiverId == request.auth.uid;
      allow create: if isSignedIn();
      allow delete: if isSignedIn() && resource.data.receiverId == request.auth.uid;
    }
  }
}
